# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#.idea/

# Node / frontend
web/node_modules

# Frontend build output is embedded by the Rust binary, not committed.
# Keep the directory itself (rust-embed needs it to exist at compile time).
web/dist/*
!web/dist/.gitkeep

# Persisted config + runtime artifacts (written at runtime)
fluxgate-data.json
fluxgate-data.json.tmp
fluxgate-certs/
fluxgate-access.log
fluxgate-events.log
fluxgate-geoip/
*.mmdb

*.local
.DS_Store
.vscode
.idea
